---
import '../styles/tokens.css';
import '../styles/blueprint.css';
import Header from '../components/Header.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Agent Ledger -- Verifiable, composable agent execution',
  description = 'An open, vendor-neutral specification for how AI agents do work together and how humans verify that work was done correctly.'
} = Astro.props;
---
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body class="blueprint-page">
  <div class="noise-overlay"></div>
  <div class="macro-grid"></div>

  <div class="blueprint-content">
    <Header />
    <slot />
  </div>
</body>
</html>
