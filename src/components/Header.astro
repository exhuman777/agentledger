---
interface Props {
  activeNav?: string;
}
const { activeNav = '' } = Astro.props;
---
<header class="site-header">
  <a href="/" class="header-logo">AGENT<span>LEDGER</span></a>
  <nav class="header-nav">
    <a href="/docs/concepts/what-is-agent-ledger" class:list={[{ active: activeNav === 'docs' }]}>Docs</a>
    <a href="/docs/spec/workflow" class:list={[{ active: activeNav === 'spec' }]}>Specification</a>
    <a href="/docs/examples/code-review" class:list={[{ active: activeNav === 'examples' }]}>Examples</a>
    <a href="https://github.com/agentledger/agentledger" target="_blank" rel="noopener">GitHub</a>
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 32px;
    font-family: var(--mono);
    font-size: 11px;
    border-bottom: 1px solid var(--border);
  }

  .header-logo {
    font-weight: 700;
    font-size: 13px;
    letter-spacing: -0.02em;
    color: #ffffff;
    text-decoration: none;
  }

  .header-logo span {
    color: var(--accent);
  }

  .header-nav {
    display: flex;
    gap: 24px;
  }

  .header-nav a {
    color: rgba(224, 224, 224, 0.5);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 10px;
    transition: color 0.1s;
  }

  .header-nav a:hover {
    color: #ffffff;
  }

  .header-nav a.active {
    color: var(--accent);
  }
</style>
