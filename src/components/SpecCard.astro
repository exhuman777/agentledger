---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  code: string;
}
const { title, subtitle, description, code } = Astro.props;
---
<div class="spec-card">
  <div class="spec-card-header">
    <span>{title}</span>
    <div class="status-dot"></div>
  </div>
  <div class="spec-card-body">
    <h3>{subtitle}</h3>
    <p>{description}</p>
    <code>{code}</code>
  </div>
</div>

<style>
  .spec-card {
    border: 1px solid var(--ink);
    background: var(--bg-card);
  }
  .spec-card-header {
    padding: 8px 12px;
    background: var(--ink);
    color: var(--bg-base);
    font-family: var(--mono);
    font-size: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .status-dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    animation: blink 2s infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .spec-card-body {
    padding: 16px;
  }
  .spec-card-body h3 {
    font-family: var(--mono);
    font-size: 14px;
    margin-bottom: 8px;
  }
  .spec-card-body p {
    font-size: 13px;
    line-height: 1.5;
    color: rgba(15, 15, 15, 0.7);
    margin-bottom: 12px;
  }
  .spec-card-body code {
    font-family: var(--mono);
    font-size: 11px;
    background: rgba(15, 15, 15, 0.05);
    padding: 2px 6px;
  }
</style>
