---
interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>;
}
const { headings } = Astro.props;
const tocHeadings = headings.filter(h => h.depth <= 3);
---
<aside class="toc">
  <div class="toc-title">On this page</div>
  {tocHeadings.map(h => (
    <a
      href={`#${h.slug}`}
      class:list={[{ 'toc-sub': h.depth === 3 }]}
    >
      {h.text}
    </a>
  ))}
</aside>

<style>
  .toc {
    padding: 24px 16px;
    font-family: var(--mono);
    font-size: 10px;
    position: sticky;
    top: 49px;
    height: calc(100vh - 49px);
    border-left: 1px solid var(--border);
  }
  .toc-title {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: 12px;
    font-size: 9px;
  }
  .toc a {
    display: block;
    padding: 3px 0;
    color: rgba(15, 15, 15, 0.5);
    text-decoration: none;
  }
  .toc a:hover {
    color: var(--ink);
  }
  .toc a.active {
    color: var(--accent);
  }
  .toc-sub {
    padding-left: 8px;
    font-size: 9px;
  }
</style>
