---
interface Props {
  label?: string;
}
const { label = 'Note' } = Astro.props;
---
<div class="callout">
  <strong>{label}:</strong>
  <slot />
</div>

<style>
  .callout {
    border-left: 3px solid var(--accent);
    padding: 12px 16px;
    background: rgba(51, 255, 119, 0.05);
    margin: 16px 0 24px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink);
  }
  .callout strong {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>
