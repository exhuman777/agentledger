---
interface Props {
  label?: string;
}
const { label = 'Note' } = Astro.props;
---
<div class="callout">
  <strong>{label}:</strong>
  <slot />
</div>

<style>
  .callout {
    border-left: 3px solid var(--accent);
    padding: 12px 16px;
    background: rgba(234, 78, 36, 0.04);
    margin: 16px 0 24px;
    font-size: 13px;
    line-height: 1.6;
  }
  .callout strong {
    font-family: var(--mono);
    font-size: 11px;
  }
</style>
